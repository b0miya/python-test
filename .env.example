# ── Google OAuth 설정 ──────────────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 발급
# (Google Classroom API 불필요 — 로그인 전용)
GOOGLE_CLIENT_ID=여기에_클라이언트_ID_입력.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=여기에_클라이언트_시크릿_입력

# ── Anthropic API 키 ────────────────────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에_API_키_입력

# ── 교사 이메일 (쉼표로 구분, 대시보드 접근 권한) ───────────────────
TEACHER_EMAILS=teacher@school.edu,admin@school.edu

# ── 앱 보안 키 (랜덤 문자열로 교체) ────────────────────────────────
SECRET_KEY=여기에_랜덤_문자열_입력

# ── 개발 환경에서 HTTP 허용 (배포 시 제거) ─────────────────────────
OAUTHLIB_INSECURE_TRANSPORT=1
